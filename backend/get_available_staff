<?php
include '../backend/dbcon.php';  // Database connection

$role = $_GET['role'] ?? '';

if ($role) {
    // Fetch staff by role from the staff table
    $sql = "SELECT staff_ID, staff_name FROM staff WHERE role = '$role' OR other_role = '$role'";
    $result = $conn->query($sql);

    $staffData = [];
    if ($result->num_rows > 0) {
        while ($row = $result->fetch_assoc()) {
            $staffData[] = $row;
        }
    }

    // Return the staff data in JSON format
    echo json_encode($staffData);
} else {
    echo json_encode([]);  // Return an empty array if no role is provided
}
?>
